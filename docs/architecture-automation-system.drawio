        <mxCell id="pipe-verify" value="Independent Verification (AD-2)&#xa;Build: config.build.command&#xa;Tests: config.test.command&#xa;Plugins: pre_review_checks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="pipe-layer">
