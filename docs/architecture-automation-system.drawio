        <!-- ========== RIGHT SIDEBAR ========== -->

        <!-- Token cost -->
        <mxCell id="80" value="&lt;b&gt;Token Cost Per Story&lt;/b&gt;&lt;br&gt;&lt;br&gt;Orchestrator: ~10-20K tokens&lt;br&gt;Subagent: ~6-13K tokens&lt;br&gt;bmpipe (5 Claude sessions): ~50-200K&lt;br&gt;&lt;br&gt;&lt;b&gt;Overhead: 5-20%&lt;/b&gt;&lt;br&gt;&lt;b&gt;bmpipe workflows: 80-95%&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1240" y="80" width="230" height="150" as="geometry"/>
        </mxCell>

        <!-- Exit codes -->
        <mxCell id="81" value="&lt;b&gt;bmpipe Exit Codes&lt;/b&gt;&lt;br&gt;&lt;br&gt;0 — Success&lt;br&gt;1 — Workflow failure&lt;br&gt;2 — Review max retries&lt;br&gt;3 — Human required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1240" y="260" width="230" height="110" as="geometry"/>
        </mxCell>

        <!-- System loops -->
        <mxCell id="82" value="&lt;b&gt;System Loops&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. &lt;b&gt;Fix-Verify&lt;/b&gt; (bmpipe)&lt;br&gt;   review → fix → re-verify&lt;br&gt;   Max: max_retries (2)&lt;br&gt;&lt;br&gt;2. &lt;b&gt;Classification-Patch&lt;/b&gt; (orch)&lt;br&gt;   classify → SendMessage → apply&lt;br&gt;&lt;br&gt;3. &lt;b&gt;Re-Plan&lt;/b&gt; (orch)&lt;br&gt;   done → merge → re-evaluate&lt;br&gt;   → spawn next stories&lt;br&gt;&lt;br&gt;4. &lt;b&gt;Epic Loop&lt;/b&gt; (orch)&lt;br&gt;   epic done → retro → next epic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
