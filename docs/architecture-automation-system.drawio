        <!-- 6-category taxonomy box -->
        <mxCell id="29" value="&lt;b&gt;6-Category Taxonomy&lt;/b&gt;&lt;br&gt;&lt;br&gt;[FIX] → auto-apply&lt;br&gt;[SECURITY] → auto-apply + verify&lt;br&gt;[TEST-FIX] → auto-apply&lt;br&gt;[DEFER] → log only&lt;br&gt;[SPEC-AMEND] → escalate&lt;br&gt;[DESIGN] → escalate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="490" y="460" width="170" height="150" as="geometry"/>
