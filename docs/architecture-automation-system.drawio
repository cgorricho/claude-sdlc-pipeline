          <mxGeometry x="40" y="90" width="200" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="human" value="Carlos&#xa;(Main Session Terminal)" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="human-layer">
          <mxGeometry x="50" y="50" width="100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="human-actions" value="• Confirms execution plan&#xa;• Resolves [DESIGN] findings&#xa;• Resolves [SPEC-AMEND] findings&#xa;• Handles merge conflicts&#xa;• Triggers retrospectives&#xa;• Reviews trace gate decisions" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="human-layer">
          <mxGeometry x="15" y="150" width="170" height="110" as="geometry" />
        </mxCell>

        <!-- ==================== ORCHESTRATOR LAYER ==================== -->
        <mxCell id="orch-layer" value="TRACK ORCHESTRATOR SKILL (Main Claude Code Session)" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="260" y="90" width="460" height="1060" as="geometry" />
        </mxCell>

        <!-- Step 1: Dependency Graph -->
        <mxCell id="step1" value="1. Generate Dependency Graph&#xa;&#xa;Parse epics.md + CSV&#xa;Resolve dependencies&#xa;Identify parallel tracks&#xa;Detect shared-file conflicts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="50" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Step 2: Plan -->
        <mxCell id="step2" value="2. Plan Parallel Tracks&#xa;&#xa;Apply max concurrency (3)&#xa;Check file ownership overlap&#xa;Present plan to human" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="170" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 3: Spawn -->
        <mxCell id="step3" value="3. Spawn Subagents&#xa;&#xa;Agent tool (background: true)&#xa;One subagent per story&#xa;Create story branch&#xa;Stagger launches (8s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="280" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Step 4: Wait for notifications -->
        <mxCell id="step4" value="4. Receive Subagent&#xa;Completion Notifications&#xa;&#xa;(Claude Code native —&#xa;no polling, no sentinels)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="400" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 5: Classify -->
        <mxCell id="step5" value="5. Classify Findings&#xa;(LLM Reasoning — Tier 3)&#xa;&#xa;Read review-findings.json&#xa;Read story spec (ACs)&#xa;Apply 6-category taxonomy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;fontStyle=1;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="510" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Classification taxonomy -->
        <mxCell id="taxonomy" value="6-Category Taxonomy&#xa;&#xa;[FIX] → auto-apply&#xa;[SECURITY] → auto-apply + elevated verify&#xa;[TEST-FIX] → auto-apply&#xa;[DEFER] → log only&#xa;[SPEC-AMEND] → escalate to human&#xa;[DESIGN] → escalate to human" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="250" y="500" width="190" height="120" as="geometry" />
        </mxCell>

        <!-- Step 6: Fix cycle -->
        <mxCell id="step6" value="6. Coordinate Fix Cycle&#xa;&#xa;SendMessage → subagent:&#xa;&quot;Apply patches #N, re-test&quot;&#xa;Receive results&#xa;Loop if tests fail (max_retries)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="640" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Step 7: Resume trace -->
        <mxCell id="step7" value="7. Resume Trace&#xa;&#xa;SendMessage → subagent:&#xa;&quot;bmpipe --resume-from trace&quot;&#xa;Receive gate decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="760" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Step 8: Complete -->
        <mxCell id="step8" value="8. Story Completion&#xa;&#xa;Merge story branch → main&#xa;Update CSV (single writer)&#xa;Check epic completion&#xa;Re-evaluate dependency graph&#xa;Spawn newly unblocked stories" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="orch-layer">
          <mxGeometry x="30" y="870" width="200" height="110" as="geometry" />
        </mxCell>

