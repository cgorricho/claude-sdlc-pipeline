<mxfile host="app.diagrams.net" type="device">
  <diagram id="arch" name="Automation Architecture">
    <mxGraphModel dx="2000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="2" value="&lt;b&gt;BMAD SDLC Automation Architecture&lt;/b&gt;&lt;br&gt;&lt;i&gt;Track Orchestrator Skill + Subagents + bmpipe + BMAD Workflows&lt;/i&gt;" style="text;html=1;fontSize=16;align=center;" parent="1" vertex="1">
          <mxGeometry x="350" y="10" width="500" height="50" as="geometry"/>
        </mxCell>

        <!-- ========== HUMAN ========== -->
