        <!-- Subagent internal flow -->
        <mxCell id="sub-flow" value="Each Subagent Executes:&#xa;&#xa;1. bmpipe run --story {id}&#xa;   --stop-after review&#xa;&#xa;2. Report findings to&#xa;   orchestrator&#xa;&#xa;3. [on SendMessage]&#xa;   Apply patches, re-test&#xa;&#xa;4. [on SendMessage]&#xa;   bmpipe --resume-from trace&#xa;&#xa;5. Report gate decision&#xa;&#xa;Token cost while blocked&#xa;on bmpipe Bash call: $0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="sub-layer">
          <mxGeometry x="20" y="460" width="220" height="260" as="geometry" />
        </mxCell>

        <!-- Subagent idle note -->
        <mxCell id="idle-note" value="Subagents are BLOCKED&#xa;while bmpipe runs —&#xa;zero token burn.&#xa;&#xa;Tokens consumed only&#xa;during reasoning +&#xa;reporting phases." style="text;html=1;fontSize=9;fontStyle=2;align=left;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;" vertex="1" parent="sub-layer">
          <mxGeometry x="30" y="750" width="200" height="100" as="geometry" />
        </mxCell>

