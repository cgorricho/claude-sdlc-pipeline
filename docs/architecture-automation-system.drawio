        </mxCell>

        <!-- ==================== EXIT CODES ==================== -->
        <mxCell id="exit-codes" value="bmpipe Exit Codes&#xa;&#xa;0 — Story completed successfully&#xa;1 — Workflow failure (contract violation, build failure)&#xa;2 — Code review failed after max retries&#xa;3 — Automation paused — human judgment required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1300" y="650" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- ==================== INFRASTRUCTURE NOTE ==================== -->
        <mxCell id="infra-note" value="Infrastructure Requirements&#xa;&#xa;✓ Claude Code CLI (bmpipe wraps it)&#xa;✓ Python 3.11+&#xa;✓ BMAD Method installed in target project&#xa;✗ tmux (REMOVED — subagents replace it)&#xa;✗ Sentinel files (REMOVED)&#xa;✗ Polling loops (REMOVED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1300" y="800" width="280" height="150" as="geometry" />
        </mxCell>

        <!-- ==================== LOOPS ANNOTATION ==================== -->
        <mxCell id="loops-title" value="System Loops" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1300" y="980" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="loops-list" value="1. Fix-Verify Loop (bmpipe internal)&#xa;   review → fix → re-verify → review&#xa;   Max: config.review.max_retries (default 2)&#xa;&#xa;2. Classification-Patch Loop (orchestrator)&#xa;   classify → SendMessage → apply → re-test&#xa;   Max: same max_retries&#xa;&#xa;3. Re-Plan Loop (orchestrator)&#xa;   story done → merge → re-evaluate graph&#xa;   → spawn newly unblocked stories&#xa;   Until: all stories in epic done&#xa;&#xa;4. Epic Loop (orchestrator)&#xa;   epic done → retro gate → next epic&#xa;   Until: all epics complete" style="text;html=1;fontSize=10;align=left;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1300" y="1005" width="280" height="220" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
