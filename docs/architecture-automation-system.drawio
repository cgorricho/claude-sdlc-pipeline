          <mxGeometry x="30" y="80" width="180" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="Carlos&lt;br&gt;(Main Session)" style="shape=mxgraph.basic.smiley;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="70" y="120" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="• Confirms execution plan&lt;br&gt;• Resolves [DESIGN]&lt;br&gt;• Resolves [SPEC-AMEND]&lt;br&gt;• Handles merge conflicts&lt;br&gt;• Triggers retrospectives" style="text;html=1;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="40" y="195" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- ========== ORCHESTRATOR ========== -->
        <mxCell id="20" value="&lt;b&gt;TRACK ORCHESTRATOR SKILL&lt;/b&gt;&lt;br&gt;(Main Claude Code Session — LLM Reasoning)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
          <mxGeometry x="250" y="80" width="420" height="880" as="geometry"/>
        </mxCell>

        <mxCell id="21" value="1. Generate&lt;br&gt;Dependency Graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="130" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="2. Plan Parallel&lt;br&gt;Tracks (max 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="210" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="3. Spawn Subagents&lt;br&gt;(background, per-story branch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="290" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="24" value="4. Receive Notifications&lt;br&gt;(native — no polling)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="380" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="25" value="&lt;b&gt;5. CLASSIFY FINDINGS&lt;/b&gt;&lt;br&gt;(LLM Reasoning — Tier 3)&lt;br&gt;Read findings JSON + story ACs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="470" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="26" value="6. Coordinate Fix Cycle&lt;br&gt;SendMessage → subagent&lt;br&gt;&quot;Apply patches, re-test&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="600" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="27" value="7. Resume Trace&lt;br&gt;SendMessage → subagent&lt;br&gt;&quot;bmpipe --resume-from trace&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="700" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="28" value="8. Story Complete&lt;br&gt;Merge branch → main&lt;br&gt;Update CSV · Re-plan · Spawn next" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="280" y="800" width="180" height="70" as="geometry"/>
